NEXT_PUBLIC_APP_NAME="Connect Edu Admin"
NEXT_PUBLIC_APP_ENV="development"

# Backend API base URL (server-side only; never exposed to the browser).
BACKEND_API_URL="http://localhost:4000"

# Cookie configuration
SESSION_COOKIE_NAME="connect_edu_admin_session"
SESSION_REFRESH_COOKIE_NAME="connect_edu_admin_refresh"
SESSION_COOKIE_SECURE="false"
